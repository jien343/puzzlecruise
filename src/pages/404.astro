---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404: Page Not Found - PuzzleCruise" description="The page you're looking for doesn't exist.">
    <Header />
    <main class="flex-grow w-full max-w-4xl mx-auto px-4 py-20 flex flex-col items-center justify-center text-center space-y-6">
        <h1 class="text-7xl md:text-9xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-red-600">
            404
        </h1>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-200">
            Lost at Sea?
        </h2>
        <p class="text-gray-400 max-w-lg text-lg">
            We couldn't find the page you're looking for. It might have been moved, or you may have typed the URL incorrectly.
        </p>
        <a href="/" class="mt-8 px-8 py-4 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-md font-bold text-white transition-colors shadow-lg">
            Return to Homepage
        </a>
    </main>
    <Footer />
</Layout>
