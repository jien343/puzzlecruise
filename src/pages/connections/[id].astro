---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdWrapper from '../../components/AdWrapper.astro';

export async function getStaticPaths() {
    const entries = await getCollection('connections');
    // Sort ascending by date to calculate prev/next logically
    entries.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
    
    return entries.map((entry, index) => ({
        params: { id: entry.id },
        props: { 
            entry,
            prevEntry: index > 0 ? entries[index - 1] : null,
            nextEntry: index < entries.length - 1 ? entries[index + 1] : null
        },
    }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);

// Build FAQ Schema dynamically from the title and date
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What are the Connections hints for ${entry.data.date.toISOString().split('T')[0]}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We provide spoiler-free, gradual hints for today's NYT Connections. Click into the page to reveal hints layer by layer without ruining the puzzle!"
      }
    }
  ]
};
---

<Layout title={`${entry.data.title} - PuzzleCruise`} description={`Gradual, spoiler-free hints for NYT Connections on ${entry.data.date.toISOString().split('T')[0]}.`} type="article">
    <!-- Inject JSON-LD Schema for Google Rich Snippets -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    
    <Header />
    
    <main class="flex-grow w-full max-w-4xl mx-auto px-4 py-8 space-y-6">
        <!-- Breadcrumbs (Microdata for Google Rich Snippets) -->
        <nav aria-label="Breadcrumb" class="mb-4 text-sm text-gray-500" itemscope itemtype="https://schema.org/BreadcrumbList">
            <ol class="flex space-x-2">
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="/" class="hover:text-gray-300 transition-colors"><span itemprop="name">Home</span></a>
                    <meta itemprop="position" content="1" />
                </li>
                <span>/</span>
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="/connections/" class="hover:text-gray-300 transition-colors"><span itemprop="name">Connections</span></a>
                    <meta itemprop="position" content="2" />
                </li>
                <span>/</span>
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
                    <span itemprop="name" class="text-gray-400">{entry.data.date.toISOString().split('T')[0]}</span>
                    <meta itemprop="position" content="3" />
                </li>
            </ol>
        </nav>

        <div class="border-b border-gray-800 pb-4">
            <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-3">{entry.data.title}</h1>
            <div class="flex justify-between items-center">
                <p class="text-orange-400 font-semibold">{entry.data.date.toISOString().split('T')[0]}</p>
                <!-- Interactive Copy Link Button to boost Social Signals -->
                <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied to clipboard!')" class="text-xs font-medium bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded transition-colors flex items-center gap-1.5 text-gray-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                    Copy Link
                </button>
            </div>
        </div>

        <AdWrapper />

        <!-- KOL Persona Block to engage users immediately -->
        <div class="bg-blue-900/20 border border-blue-800/50 rounded-lg p-4 mb-6">
            <h3 class="text-blue-300 font-bold mb-2 text-sm uppercase tracking-wide">Editor's Note:</h3>
            <p class="text-sm text-blue-100/70 italic">Today's puzzle setter woke up choosing violence... But don't worry, we've broken down the hints into three layers: Category, Synonym, and the Final Answer. Reveal them slowly to save your streak!</p>
        </div>

        <article class="prose prose-invert max-w-none">
            <Content />
        </article>

        <AdWrapper />

        <!-- Pagination (Prev / Next) for SEO Internal Linking -->
        <nav class="flex justify-between items-center pt-8 border-t border-gray-800 mt-12">
            <div>
                {prevEntry && (
                    <a href={`/connections/${prevEntry.id}`} class="flex flex-col text-left group">
                        <span class="text-xs text-gray-500 uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Previous</span>
                        <span class="text-lg font-bold text-gray-300 group-hover:text-white transition-colors">&larr; {prevEntry.data.date.toISOString().split('T')[0]}</span>
                    </a>
                )}
            </div>
            <div class="text-right">
                {nextEntry && (
                    <a href={`/connections/${nextEntry.id}`} class="flex flex-col text-right group">
                        <span class="text-xs text-gray-500 uppercase tracking-wider mb-1 group-hover:text-orange-500 transition-colors">Next Day</span>
                        <span class="text-lg font-bold text-gray-300 group-hover:text-white transition-colors">{nextEntry.data.date.toISOString().split('T')[0]} &rarr;</span>
                    </a>
                )}
            </div>
        </nav>
    </main>

    <Footer />
</Layout>
