---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdWrapper from '../../components/AdWrapper.astro';

const entries = await getCollection('strands');
const sortedEntries = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title="Strands Archives - PuzzleCruise">
    <Header />
    
    <main class="flex-grow w-full max-w-3xl mx-auto px-4 py-8 space-y-8">
        <div>
            <h1 class="text-3xl font-extrabold text-white mb-2">Strands Archives</h1>
            <p class="text-gray-400">Browse all past Strands layouts.</p>
        </div>
        
        <AdWrapper />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {sortedEntries.map(entry => (
                <a href={`/strands/${entry.id}`} class="block p-5 bg-gray-800/40 hover:bg-gray-800/70 border border-gray-700/50 rounded-lg transition-colors group">
                    <div class="text-sm text-orange-400 font-semibold mb-1 group-hover:text-orange-300">{entry.data.date.toISOString().split('T')[0]}</div>
                    <div class="text-lg text-gray-200 font-medium">{entry.data.title}</div>
                </a>
            ))}
        </div>
    </main>

    <Footer />
</Layout>
